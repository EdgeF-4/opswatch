{
  "brand_name": "OpsWatch",
  "store_path": "/data/opswatch.db",
  "retention_days": 30,

  "theme": {
    "tagline": "Self-hosted operations monitoring",
    "accent": "#3b82f6"
  },

  "dashboard": { "host": "0.0.0.0", "port": 8765 },

  "ingest": { "enabled": true, "token_env": "OPSWATCH_INGEST_TOKEN" },

  "scheduler": {
    "tick_seconds": 2,
    "jobs": [
      { "name": "heartbeat", "kind": "builtin", "target": "heartbeat", "interval_seconds": 15 },
      { "name": "daily_report", "kind": "builtin", "target": "sample_report", "interval_seconds": 60 }
    ]
  },

  "monitors": {
    "tick_seconds": 5,
    "warmup_seconds": 5,
    "checks": [
      { "name": "disk_space", "type": "resource", "metric": "disk", "path": "/", "min_free_pct": 10 },
      { "name": "memory", "type": "resource", "metric": "memory", "min_free_pct": 5 },
      { "name": "cpu", "type": "resource", "metric": "cpu", "max_used_pct": 95 },
      { "name": "load", "type": "resource", "metric": "load", "max_load_per_cpu": 4.0 },
      { "name": "heartbeat_fresh", "type": "job_freshness", "job": "heartbeat", "max_age_seconds": 60 }
    ]
  },

  "notifications": {
    "console": true,
    "file": "/data/alerts.log",
    "webhook_env": "OPSWATCH_WEBHOOK_URL"
  },

  "reporting": {
    "windows": [["24h", 86400], ["7d", 604800], ["30d", 2592000]]
  }
}
